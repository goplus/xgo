type Scale const (
	Tiny   = 0.25
	Small  = 0.5
	Normal = 1.0
	Large  = 2.0
)

type LogLevel const (
	Debug = "debug"
	Info  = "info"
	Warn  = "warn"
	Error = "error"
)

type Vowel const (
	A = 'a'
	E = 'e'
	I = 'i'
	O = 'o'
	U = 'u'
)

type Toggle const (
	Off = false
	On  = true
)

echo Tiny, Small, Normal, Large
echo Debug, Info, Warn, Error
echo A, E, I
echo Off, On
